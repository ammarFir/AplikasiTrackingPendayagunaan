<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f0f0f0"
    tools:context=".MonitoringProgram">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header"
        android:backgroundTint="#97D2A5"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="20dp"
                android:textColor="#1F1E1E"
                android:layout_weight="1"
                android:text="Monitoring Program"
                android:textSize="23dp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginTop="7dp"
                android:layout_marginRight="40dp"
                android:background="@drawable/ic_circle_black"
                app:srcCompat="@drawable/logokoceng" />

        </LinearLayout>

    </LinearLayout>

    <!-- Content Area dengan ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F0F0F0"
            android:paddingTop="16dp">

            <!-- CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMain"
                android:layout_width="0dp"
                app:strokeWidth="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:orientation="vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp">

                    <!-- RecyclerView untuk tahapan -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTahapan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:paddingBottom="16dp" />

                    <!-- 2 Tombol bawah -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnUpdateProgress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_update"
                            android:elevation="4dp"
                            android:text="Update Progress"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnProgressSelesai"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_progress"
                            android:text="Progress Selesai"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Garis hijau kiri -->
                <View
                    android:id="@+id/viewGarisHijau"
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:elevation="0dp"
                    android:background="@drawable/bg_garis_hijau"
                    app:layout_constraintBottom_toBottomOf="@id/cardMain"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/cardMain" />

            </com.google.android.material.card.MaterialCardView>

            <!-- BADGE UPZPRENEUR -->
            <FrameLayout
                android:id="@+id/badgeWrapper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge"
                android:paddingEnd="12dp"
                android:padding="8dp"
                android:layout_marginTop="-40dp"
                android:layout_marginLeft="32dp"
                app:layout_constraintTop_toTopOf="@id/cardMain"
                app:layout_constraintStart_toStartOf="@id/cardMain">

                <TextView
                    android:id="@+id/badgeUpzpreneur"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UPZPRENEUR"
                    android:background="@drawable/bg_rounded"
                    android:backgroundTint="#6663BD"
                    android:padding="10dp"
                    android:textColor="#ffffff"
                    android:textStyle="bold"
                    android:textSize="19sp"/>

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</LinearLayout>