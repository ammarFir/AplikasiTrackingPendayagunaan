<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="vertical">

        <!-- Row title + logo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="7dp"
                android:layout_weight="1"
                android:textColor="#ffffff
"
                android:text="Tracking Mustahiq"
                android:textSize="25dp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginTop="3dp"
                android:layout_marginRight="10dp"
                android:background="@drawable/ic_circle_black"
                app:srcCompat="@drawable/logokoceng" />

        </LinearLayout>

        <!-- 2 Card di bawah row title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal"

            android:paddingTop="2dp"
            android:paddingBottom="3dp">

            <!-- Card 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="180dp"
                android:layout_height="60dp"
                android:layout_marginLeft="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="6dp">

                    <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp">

                        <View
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_circle_green_light" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            app:srcCompat="@drawable/ic_people"
                            app:tint="#2E7D32" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:maxLines="2"
                        android:text="Penerima Program "
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalPenerima"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="67"
                        android:textStyle="bold"
                        android:textSize="28sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card 2 -->
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"></View>

            <androidx.cardview.widget.CardView
                android:layout_width="180dp"
                android:layout_height="60dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="6dp">

                    <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp">

                        <View
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_circle_green_light" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            app:srcCompat="@drawable/ic_clipboard_check"
                            app:tint="#2E7D32" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:maxLines="2"
                        android:text="Program Selesai"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProgramSelesai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="15"
                        android:textStyle="bold"
                        android:textSize="28sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>


        </LinearLayout>

        <!-- Card 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="370dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp">

                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_circle_green_light" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/ic_money"
                        app:tint="#2E7D32" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Total Dana"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1F1E1E" />

                <TextView
                    android:id="@+id/tvTotalDana"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="Rp 45,000,000"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <LinearLayout
            android:id="@+id/btnAdd"
            android:layout_width="370dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_btn_outline_white"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="24dp"
                android:layout_height="24dp">

                <View
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_circle_white_outline" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    app:srcCompat="@drawable/ic_plus"
                    app:tint="#FFFFFF" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Tambah Penerima Baru"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>



    </LinearLayout>

    <!-- Konten scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Ganti semua FrameLayout hardcoded dengan ini -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPenerima"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:layout_height="wrap_content"/>


        </LinearLayout>



    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/BottomNavStyle"
        app:itemIconTint="@drawable/bottom_nav_color"
        app:itemTextAppearanceActive="@style/BottomNavTextActive"
        app:itemTextAppearanceInactive="@style/BottomNavTextInactive"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>