<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="20dp"
    android:elevation="10dp"
    android:orientation="horizontal">

    <!-- Kiri: dot + garis -->
    <LinearLayout
        android:id="@+id/leftSection"
        android:layout_width="30dp"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <View
            android:id="@+id/line2"
            android:layout_width="2dp"
            android:layout_height="15dp"
            android:background="#4B4B4B" />
        <View
            android:id="@+id/dot"
            android:layout_width="12dp"
            android:layout_height="12dp"

            android:background="@drawable/ic_dot_blue" />

        <View
            android:id="@+id/line"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#4B4B4B" />

    </LinearLayout>

    <!-- Kanan: konten -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:elevation="10dp"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <!-- Nama Tahapan -->
        <TextView
            android:id="@+id/tvNamaTahapan"
            android:layout_width="300dp"
            android:layout_height="40dp"
            android:background="#5F7BDD"
            android:elevation="10dp"
            android:gravity="center_vertical"
            android:paddingLeft="10dp"
            android:text="Nama Tahapan"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />

        <!-- DASHED LINE VERTIKAL (langsung di bawah nama tahapan) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.yourname.aplikasitrackingpendayagunaan.DashedLineView
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:layout_marginBottom="10dp" />

            <!-- Konten Kanan (Tambah Bukti + Form) -->
            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:elevation="10dp"
                android:orientation="vertical">

                <!-- TOMBOL Tambah Bukti (awal) -->
                <LinearLayout
                    android:id="@+id/btnTambahBukti"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginRight="20dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="@drawable/dashed_line" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:elevation="10dp"
                        android:text="⊕  Tambah Bukti"
                        android:textColor="#888888"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- FORM (hidden awal) -->
                <LinearLayout
                    android:id="@+id/formLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:elevation="10dp"
                    android:visibility="gone">

                    <!-- Deskripsi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:elevation="10dp"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="30dp"
                            android:layout_height="2dp"
                            android:background="@drawable/dashed_line" />

                        <EditText
                            android:id="@+id/etDeskripsi"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:layout_marginRight="80dp"
                            android:layout_weight="1"
                            android:background="@drawable/edittetxt_border"
                            android:hint="Tambahkan Deskripsi"
                            android:padding="8dp"
                            android:textColor="#000000"
                            android:textColorHint="#888888"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:elevation="10dp"/>

                    </LinearLayout>

                    <!-- Upload Foto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:elevation="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="30dp"
                            android:layout_height="2dp"
                            android:background="@drawable/dashed_line" />

                        <LinearLayout
                            android:id="@+id/btnUpload"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="80dp"
                            android:layout_weight="1"
                            android:background="@drawable/edittetxt_border"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+"
                                android:textColor="#888888"
                                android:textSize="26sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Upload Foto"
                                android:textColor="#888888"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Preview Foto -->
                    <ImageView
                        android:id="@+id/ivFoto"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="8dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>