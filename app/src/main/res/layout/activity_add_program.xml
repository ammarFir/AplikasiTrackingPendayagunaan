<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E4E4E4"
    android:orientation="vertical"
    tools:context=".AddProgram">


    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header"
        android:backgroundTint="#97D2A5"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="20dp"
                android:layout_weight="1"
                android:text="Detail Program"
                android:textSize="23dp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imageView10"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginTop="7dp"
                android:layout_marginRight="40dp"
                android:background="@drawable/ic_circle_black"
                app:srcCompat="@drawable/logokoceng" />

        </LinearLayout>

    </LinearLayout>


    <FrameLayout
        android:layout_width="354dp"
        android:layout_height="500dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:paddingBottom="20dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/cardadd" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingLeft="30dp"
            android:paddingTop="20dp">

            <TextView
                style="@style/TextAppearance.MaterialComponents.Headline6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Form Pengisian"
                android:textColor="#49516F"
                android:textSize="20dp"
                android:textStyle="bold" />

<!-- text nama -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:elevation="2dp"
                android:hint="Nama Mustahiq">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:hint="Pilih Program">

                <AutoCompleteTextView
                    android:paddingLeft="15dp"
                    android:id="@+id/autoComplete"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"

                    android:focusable="false"
                    android:focusableInTouchMode="false">

                </AutoCompleteTextView>

            </com.google.android.material.textfield.TextInputLayout>


            <!-- text jenis  usaha -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:elevation="2dp"
                android:hint="Jenis Usaha">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </com.google.android.material.textfield.TextInputLayout>


  <!-- text jenis  usaha -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:elevation="2dp"
                android:hint="Total Dana">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </com.google.android.material.textfield.TextInputLayout>


  <!-- text jenis  usaha -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:elevation="2dp"
                android:hint="Tanggal Mulai">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_marginTop="10dp"
                android:layout_width="280dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_form"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Foto"
                    android:textSize="14sp"
                    android:textColor="#000000"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+"
                    android:textSize="40sp"
                    android:textColor="#000000"/>



            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:background="#6663BD"
                android:layout_marginTop="40dp"
                android:layout_marginLeft="10dp"
                android:layout_width="190dp"
                android:layout_height="wrap_content"

                android:text="Tambah"/>
        </LinearLayout>


    </FrameLayout>


</LinearLayout>